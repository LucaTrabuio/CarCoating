rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Stores: public read, admin write
    match /stores/{storeId} {
      allow read: if true;
      allow create, delete: if request.auth != null && request.auth.token.role == 'super_admin';
      allow update: if request.auth != null && (
        request.auth.token.role == 'super_admin' ||
        (request.auth.token.role == 'store_admin' && storeId in request.auth.token.managed_stores)
      );
    }

    // Sub-companies: public read, super admin write
    match /sub_companies/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'super_admin';
    }

    // Campaigns: public read, admin write
    match /campaigns/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'super_admin';
    }

    // Users: self-read or super admin
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.token.role == 'super_admin' || request.auth.uid == userId
      );
      allow write: if request.auth != null && request.auth.token.role == 'super_admin';
    }

    // Master data: public read, super admin write
    match /master_data/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'super_admin';
    }

    // Blog posts: public read, super admin write
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'super_admin';
    }

    // KPI: admin read for their stores; writes must go through server (Admin SDK bypasses these rules)
    match /kpi/{storeId}/{subcol}/{docId} {
      allow read: if request.auth != null && (
        request.auth.token.role == 'super_admin' ||
        storeId in request.auth.token.managed_stores
      );
      allow write: if false;
    }

    // Inquiries: writes via server only; reads restricted to authed admins (public token lookups go through /api/inquiries/[token])
    match /inquiries/{inquiryId} {
      allow create: if false;
      allow read: if request.auth != null && request.auth.token.role in ['super_admin', 'store_admin'];
      allow update, delete: if false;
    }
  }
}
